# MFA Server config
PORT=8090
NODE_ENV=production

# API key for Protheus → mfaserver auth (generate with: openssl rand -hex 32)
API_KEY=change-me-generate-a-real-key

# Encryption master key for TOTP secrets at-rest (AES-256-GCM) — openssl rand -hex 32
MASTER_KEY=change-me-generate-a-real-key

# Redis (anti-replay + rate-limit)
REDIS_URL=redis://redis:6379

# SQLite path (inside container volume)
DB_PATH=/data/mfa.db

# TOTP settings
TOTP_ISSUER=Protheus-SAI
TOTP_WINDOW=1
